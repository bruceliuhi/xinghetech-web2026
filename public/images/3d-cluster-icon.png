<svg width="400" height="400" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="cluster1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2C4BFF;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#9122FA;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- 圆形背景 -->
  <circle cx="200" cy="200" r="180" fill="url(#cluster1)" opacity="0.1"/>
  
  <!-- 聚类图标 - 多个圆形组 -->
  <g transform="translate(200, 200)">
    <!-- 左上组 -->
    <circle cx="-50" cy="-50" r="25" fill="url(#cluster1)" opacity="0.8"/>
    <circle cx="-35" cy="-35" r="15" fill="url(#cluster1)"/>
    <circle cx="-65" cy="-35" r="12" fill="url(#cluster1)"/>
    
    <!-- 右上组 -->
    <circle cx="50" cy="-40" r="28" fill="url(#cluster1)" opacity="0.8"/>
    <circle cx="65" cy="-25" r="18" fill="url(#cluster1)"/>
    <circle cx="35" cy="-20" r="14" fill="url(#cluster1)"/>
    
    <!-- 底部组 -->
    <circle cx="0" cy="50" r="30" fill="url(#cluster1)" opacity="0.8"/>
    <circle cx="-20" cy="60" r="16" fill="url(#cluster1)"/>
    <circle cx="20" cy="65" r="16" fill="url(#cluster1)"/>
    <circle cx="0" cy="30" r="12" fill="url(#cluster1)"/>
  </g>
  
  <!-- 标识文字 -->
  <text x="200" y="360" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="#2C4BFF" text-anchor="middle">Cluster Icon</text>
  <text x="200" y="385" font-family="Arial, sans-serif" font-size="14" fill="#6B7280" text-anchor="middle">聚类图标</text>
</svg>
