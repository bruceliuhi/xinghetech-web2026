<svg width="400" height="400" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="knowledge1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2C4BFF;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#9122FA;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- 圆形背景 -->
  <circle cx="200" cy="200" r="180" fill="url(#knowledge1)" opacity="0.1"/>
  
  <!-- 知识库图标 - 书本 -->
  <g transform="translate(200, 200)">
    <!-- 书本主体 -->
    <rect x="-70" y="-60" width="140" height="120" rx="8" fill="url(#knowledge1)"/>
    
    <!-- 书脊 -->
    <rect x="-70" y="-60" width="20" height="120" fill="#9122FA"/>
    
    <!-- 页面线条 -->
    <line x1="-40" y1="-40" x2="50" y2="-40" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.8"/>
    <line x1="-40" y1="-20" x2="50" y2="-20" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.8"/>
    <line x1="-40" y1="0" x2="50" y2="0" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.8"/>
    <line x1="-40" y1="20" x2="40" y2="20" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.8"/>
    <line x1="-40" y1="40" x2="50" y2="40" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.8"/>
    
    <!-- 书签 -->
    <rect x="50" y="-60" width="15" height="80" fill="#FFD700" opacity="0.8"/>
  </g>
  
  <!-- 标识文字 -->
  <text x="200" y="360" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="#2C4BFF" text-anchor="middle">Knowledge Icon</text>
  <text x="200" y="385" font-family="Arial, sans-serif" font-size="14" fill="#6B7280" text-anchor="middle">知识库图标</text>
</svg>
